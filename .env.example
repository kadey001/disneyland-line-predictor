# Database Configuration
# For local development - use your actual database connection string
# For production, the Go service reads from Google Secret Manager automatically
DATABASE_URL="postgresql://username:password@localhost:5432/disneyland_db?sslmode=prefer"

# Next.js Configuration
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-here-change-this-in-production"

# API URLs
# Production Go service URL (update with your actual deployed URL)
WAIT_TIMES_API_URL="https://wait-times-api-602235714983.us-west2.run.app"

# Comma-separated list of origins allowed to call /api/* cross-origin.
# The app calls its own API same-origin, so this only governs third-party browsers.
# Defaults to http://localhost:3000 when unset.
ALLOWED_ORIGINS="http://localhost:3000"

# Development Environment
NODE_ENV="development"

# Optional: set to "true" to enable verbose per-request logging in the
# /api/ride-wait-times route. Leave unset/false in production to reduce noise.
DEBUG_WAIT_TIMES="false"
